---
import { contact } from "../config/artist";
import { getSectionStyles } from "../utils/sectionStyle";

interface Props { defaultBg: string; }
const { defaultBg } = Astro.props;

const { style: sectionStyle } = getSectionStyles(contact, defaultBg);
---

<section class="section" style={sectionStyle} id="contact">
  <div class="section__inner contact">
    <h2 class="section__heading">{contact.heading}</h2>
    <div class="contact__grid">
      {contact.entries.map((entry) => (
        <div class="contact__entry">
          <h3 class="contact__label">{entry.label}</h3>
          {entry.value && <p class="contact__value">{entry.value}</p>}
          {entry.email && (
            <a href={`mailto:${entry.email}`} class="contact__email">
              {entry.email}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .contact {
    text-align: center;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .contact__entry {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact__label {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
  }

  .contact__value {
    font-size: 1rem;
    opacity: 0.8;
  }

  .contact__email {
    font-size: 0.95rem;
    color: var(--color-text);
    opacity: 0.7;
    transition: opacity 0.2s ease, color 0.2s ease;
    word-break: break-all;
  }

  .contact__email:hover {
    opacity: 1;
    color: var(--color-accent);
  }
</style>
