---
import { tourDates, theme } from "../config/artist";
import { getSectionStyles } from "../utils/sectionStyle";

interface Props { defaultBg: string; }
const { defaultBg } = Astro.props;

if (!tourDates.enabled) return;

const artistName = encodeURIComponent(tourDates.bandsintown.artistName);
const { style: sectionStyle } = getSectionStyles(tourDates, defaultBg);
---

<section class="section" style={sectionStyle} id="shows">
  <div class="section__inner tour">
    <h2 class="section__heading">Upcoming Shows</h2>
    <div class="tour__widget" id="bandsintown-widget">
      <a
        class="bit-widget-initializer"
        data-artist-name={tourDates.bandsintown.artistName}
        data-follow-section-position="hidden"
        data-display-local-dates="false"
        data-display-past-dates="false"
        data-display-lineup="false"
        data-display-play-my-city="true"
        data-display-start-time="false"
        data-auto-style="false"
        data-text-color={theme.textColor}
        data-link-color={theme.accentColor}
        data-background-color="transparent"
        data-display-limit="10"
        data-link-text-color={theme.textColor}
        data-separator-color="rgba(255,255,255,0.1)"
      ></a>
    </div>
  </div>
</section>

<script is:inline src="https://widgetv3.bandsintown.com/main.min.js"></script>

<style>
  .tour__widget {
    max-width: 800px;
    margin: 0 auto;
    min-height: 200px;
  }

  .tour__widget :global(.bit-button), .tour__widget :global(.bit-play-my-city-cta) {
    background-color: var(--color-accent) !important;
    color: var(--color-bg) !important;
    border: 1px solid var(--color-accent) !important;
    border-radius: 100px !important;
  }

  .tour__widget :global(.bit-button:hover), .tour__widget :global(.bit-play-my-city-cta:hover) {
    opacity: 0.85 !important;
  }
</style>
