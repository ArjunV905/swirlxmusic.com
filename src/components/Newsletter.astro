---
import { newsletter } from "../config/artist";
import { getSectionStyles } from "../utils/sectionStyle";

interface Props { defaultBg: string; }
const { defaultBg } = Astro.props;

if (!newsletter.enabled) return;

const { style: sectionStyle } = getSectionStyles(newsletter, defaultBg);

const embedHtml = await import("../config/newsletter-embed.html?raw").then(
  (m) => m.default
);
const hasEmbed = embedHtml.replace(/<!--[\s\S]*?-->/g, "").trim().length > 0;
---

<section class="section" style={sectionStyle} id="newsletter">
  <div class="section__inner nl">
    <h2 class="section__heading">{newsletter.heading}</h2>
    {newsletter.subheading && (
      <p class="nl__sub">{newsletter.subheading}</p>
    )}
    {hasEmbed && (
      <div class="nl__embed" id="nl-embed" set:html={embedHtml} />
    )}
  </div>
</section>

{hasEmbed && (
  <script is:inline>
    (function () {
      var container = document.getElementById("nl-embed");
      if (!container) return;
      var scripts = container.querySelectorAll("script");
      scripts.forEach(function (original) {
        var script = document.createElement("script");
        if (original.src) {
          script.src = original.src;
        } else {
          script.textContent = original.textContent;
        }
        original.parentNode.removeChild(original);
        document.body.appendChild(script);
      });
    })();
  </script>
)}

<style>
  .nl {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .nl__sub {
    margin: -1.5rem auto 2rem;
    opacity: 0.7;
    font-size: 1rem;
    max-width: 50ch;
  }

  .nl__embed {
    width: 100%;
    display: flex;
    justify-content: center;
  }
</style>
