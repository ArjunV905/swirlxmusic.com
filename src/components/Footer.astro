---
import { artist } from "../config/artist";
import SocialIcons from "./SocialIcons.astro";

const year = new Date().getFullYear();
const hasLogotype = artist.logotype != null && artist.logotype.trim() !== "";
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__left">
      {hasLogotype ? (
        <img src={artist.logotype!} alt={`${artist.name} logo`} class="footer__logo" width="120" height="36" loading="lazy" />
      ) : (
        <span class="footer__name">{artist.name}</span>
      )}
      <p class="footer__copy">&copy; {year} {artist.name}. All rights reserved.</p>
    </div>
    <div class="footer__right">
      <SocialIcons size={18} />
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 1;
    background-color: var(--color-surface);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 2rem;
  }

  .footer__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer__left {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer__logo {
    height: 28px;
    width: auto;
    object-fit: contain;
    opacity: 0.7;
  }

  .footer__name {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
    opacity: 0.7;
  }

  .footer__copy {
    font-size: 0.75rem;
    opacity: 0.4;
  }

  .footer__right {
    display: flex;
    align-items: center;
  }

  @media (max-width: 640px) {
    .footer__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
