---
import { socials, type SocialsConfig } from "../config/artist";

import SpotifyIcon from "../icons/Spotify.astro";
import AppleMusicIcon from "../icons/AppleMusic.astro";
import YouTubeIcon from "../icons/YouTube.astro";
import InstagramIcon from "../icons/Instagram.astro";
import TikTokIcon from "../icons/TikTok.astro";
import TwitterIcon from "../icons/Twitter.astro";
import FacebookIcon from "../icons/Facebook.astro";
import SoundCloudIcon from "../icons/SoundCloud.astro";
import BandcampIcon from "../icons/Bandcamp.astro";
import TidalIcon from "../icons/Tidal.astro";
import LinktreeIcon from "../icons/Linktree.astro";

interface Props {
  size?: number;
  class?: string;
  /** When set (e.g. hex), overrides default icon color for this row. */
  iconColor?: string | null;
}

const { size = 22, class: className = "", iconColor } = Astro.props;

const listStyle =
  iconColor != null && iconColor.trim() !== ""
    ? ({ "--social-icon-color": iconColor.trim() } as Record<string, string>)
    : undefined;

const iconMap: Record<string, any> = {
  spotify: SpotifyIcon,
  appleMusic: AppleMusicIcon,
  youtube: YouTubeIcon,
  instagram: InstagramIcon,
  tiktok: TikTokIcon,
  twitter: TwitterIcon,
  facebook: FacebookIcon,
  soundcloud: SoundCloudIcon,
  bandcamp: BandcampIcon,
  tidal: TidalIcon,
  linktree: LinktreeIcon,
};

const platformLabels: Record<string, string> = {
  spotify: "Spotify",
  appleMusic: "Apple Music",
  youtube: "YouTube",
  instagram: "Instagram",
  tiktok: "TikTok",
  twitter: "X (Twitter)",
  facebook: "Facebook",
  soundcloud: "SoundCloud",
  bandcamp: "Bandcamp",
  tidal: "Tidal",
  linktree: "Linktree",
};

const displayOrder: (keyof SocialsConfig)[] = [
  "spotify", "appleMusic", "tidal", "soundcloud", "youtube",
  "instagram", "tiktok", "twitter", "facebook", "bandcamp", "linktree",
];

const activeSocials = displayOrder
  .filter((key) => socials[key] != null && socials[key]!.trim() !== "")
  .map((key) => [key, socials[key]!] as [keyof SocialsConfig, string]);
---

{activeSocials.length > 0 && (
  <ul class:list={["social-icons", className]} style={listStyle} role="list">
    {activeSocials.map(([platform, url]) => {
      const Icon = iconMap[platform];
      const label = platformLabels[platform] || platform;
      return (
        <li class="social-icons__item">
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={label}
            class="social-icons__link"
            data-tooltip={label}
          >
            <Icon size={size} />
          </a>
        </li>
      );
    })}
  </ul>
)}

<style>
  .social-icons {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .social-icons__item {
    position: relative;
  }

  .social-icons__link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--social-icon-color, var(--color-text));
    opacity: 0.7;
    transition: opacity 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .social-icons__link:hover {
    opacity: 1;
    color: var(--color-accent);
    transform: scale(1.15);
  }

  .social-icons__link::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    padding: 0.3rem 0.6rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    white-space: nowrap;
    border-radius: 4px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .social-icons__link:hover::after {
    opacity: 1;
    transform: translateX(-50%) translateY(-4px);
  }
</style>
