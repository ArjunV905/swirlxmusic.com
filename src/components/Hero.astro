---
import { artist, hero, theme } from "../config/artist";
import NavLinks from "./NavLinks.astro";
import SocialIcons from "./SocialIcons.astro";
import ParticleCanvas from "./ParticleCanvas";

const hasImage = hero.backgroundImage != null && hero.backgroundImage.trim() !== "";
const hasLogotype = artist.logotype != null && artist.logotype.trim() !== "";
---

<section class="hero" id="hero">
  <!-- Background layer (fixed) -->
  {hasImage ? (
    <div class="hero__bg hero__bg--image" style={`background-image: url('${hero.backgroundImage}')`} aria-hidden="true" />
  ) : (
    <div class="hero__bg hero__bg--canvas" aria-hidden="true">
      <ParticleCanvas color={hero.particleColor || theme.accentColor} client:only="react" />
    </div>
  )}

  <!-- Fixed center content: logotype + nav -->
  <div class="hero__center" id="hero-center">
    {hasLogotype ? (
      <img src={artist.logotype!} alt={`${artist.name} logo`} class="hero__logotype" width="400" height="120" />
    ) : (
      <h1 class="hero__title">{artist.name}</h1>
    )}
    <NavLinks class="hero__nav" />
  </div>

  <!-- Bottom row: social icons (scrolls with page) -->
  <div class="hero__bottom">
    <SocialIcons size={20} />
  </div>
</section>

<script>
  function initHeroScroll() {
    const center = document.getElementById("hero-center");
    if (!center) return;

    let ticking = false;

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          const vh = window.innerHeight;
          const progress = Math.min(scrollY / (vh * 0.5), 1);
          center!.style.opacity = String(1 - progress);
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
  }

  initHeroScroll();
</script>

<style>
  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Fixed background */
  .hero__bg {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  .hero__bg--image {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__bg--canvas {
    pointer-events: none;
  }

  /* Fixed centered content */
  .hero__center {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    pointer-events: auto;
    transition: opacity 0.1s ease;
    will-change: opacity;
  }

  .hero__logotype {
    max-width: min(80vw, 500px);
    height: auto;
    object-fit: contain;
  }

  .hero__title {
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1;
  }

  /* Bottom social icons - scrolls with the hero section */
  .hero__bottom {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  @media (max-width: 640px) {
    .hero__title {
      font-size: clamp(2rem, 12vw, 4rem);
    }
  }
</style>
