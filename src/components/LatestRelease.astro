---
import { Image } from "astro:assets";
import { latestRelease, theme } from "../config/artist";
import { getSectionStyles } from "../utils/sectionStyle";

if (!latestRelease.enabled) return;

const { style: sectionStyle } = getSectionStyles(latestRelease, theme.surfaceColor);

const platformLabels: Record<string, string> = {
  spotify: "Spotify",
  appleMusic: "Apple Music",
  youtube: "YouTube",
  soundcloud: "SoundCloud",
  bandcamp: "Bandcamp",
  tidal: "Tidal",
  amazonMusic: "Amazon Music",
  deezer: "Deezer",
};
---

<section class="section" style={sectionStyle} id="latest-release">
  <div class="section__inner release">
    <p class="release__tagline">{latestRelease.tagline}</p>
    <div class="release__content">
      <Image
        src={latestRelease.image}
        alt={latestRelease.imageAlt}
        class="release__artwork"
        width={400}
        height={400}
        loading="lazy"
      />
      <div class="release__info">
        <h2 class="release__title">{latestRelease.title}</h2>
        {latestRelease.streamingLinks.length > 0 && (
          <div class="release__links">
            {latestRelease.streamingLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="release__link"
              >
                {link.label || platformLabels[link.platform] || link.platform}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .release {
    text-align: center;
  }

  .release__tagline {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2.5rem;
  }

  .release__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .release__artwork {
    width: min(100%, 400px);
    height: auto;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .release__info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .release__title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--color-primary);
  }

  .release__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .release__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--color-accent);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .release__link:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }
</style>
