---
import { Image } from "astro:assets";
import { latestRelease } from "../config/artist";
import { getSectionStyles } from "../utils/sectionStyle";

interface Props { defaultBg: string; }
const { defaultBg } = Astro.props;

if (!latestRelease.enabled) return;

const { style: sectionStyle } = getSectionStyles(latestRelease, defaultBg);
---

<section class="section" style={sectionStyle} id="latest-release">
  <div class="section__inner release">
    <p class="release__tagline">{latestRelease.tagline}</p>
    <div class="release__header">
      <h3 class="release__type">{latestRelease.releaseType}</h3>
      <h2 class="release__title">{latestRelease.title}</h2>
    </div>
    <div class="release__content">
      <Image
        src={latestRelease.image}
        alt={latestRelease.imageAlt}
        class="release__artwork"
        width={400}
        height={400}
        loading="lazy"
      />
      {latestRelease.streamingLinks.length > 0 && (
        <div class="release__links">
          {latestRelease.streamingLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="release__link"
            >
              {link.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .release {
    text-align: center;
  }

  .release__tagline {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }

  .release__header {
    margin-bottom: 1rem;
  }

  .release__type {
    font-size: clamp(0.75rem, 1.5vw, 0.9rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
    opacity: 0.5;
    margin-top: 3rem;
  }

  .release__title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .release__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .release__artwork {
    width: min(100%, 500px);
    height: auto;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .release__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .release__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--color-accent);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .release__link:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }
</style>
